# ── 数据库 ──────────────────────────────────────────────
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/rugby

# ── 缓存 / 搜索 ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=                 # 用 openssl rand -hex 24 生成

# ── 认证 ────────────────────────────────────────────────
JWT_SECRET=                      # 必须！用 openssl rand -hex 32 生成，绝不可用默认值

# ── 第三方 API ──────────────────────────────────────────
GROQ_API_KEY=                    # https://console.groq.com 申请

# ── 前端（NEXT_PUBLIC_ 前缀会暴露给浏览器，勿放密钥）──────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=https://your-domain.com
